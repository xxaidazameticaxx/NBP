DB_URL=jdbc:oracle:thin:@<host>:1521:<sid>
DB_USERNAME=your_username
DB_PASSWORD=your_password
JWT_SECRET=very_long_random_secret_at_least_32_characters

# MongoDB (auth logs)
# --- Docker Compose (app in container, MongoDB on host) ---
# Required by docker-compose.yml (no defaults there):
NBP_MONGODB_URI=mongodb://host.docker.internal:27017/nbp_logs
NBP_MONGODB_DATABASE=nbp_logs

# --- Running app locally (no Docker) ---
# If you run Spring Boot directly (e.g. ./mvnw spring-boot:run), use these:
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/nbp_logs
SPRING_DATA_MONGODB_DATABASE=nbp_logs
